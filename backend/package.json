{
  "name": "lightning-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:community": "npm run build && node scripts/validateCommunityGuards.mjs",
    "serve:local": "node dist/backend/dev-server.js",
    "dev": "npm run build && npm run serve:local",
    "seed:catalog": "npm run build && node dist/backend/scripts/seedCatalog.js",
    "bootstrap:smoke-user": "node scripts/bootstrapSmokeUser.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1022.0",
    "@aws-sdk/lib-dynamodb": "^3.1022.0",
    "@types/node": "^25.5.0",
    "aws-jwt-verify": "^5.1.1",
    "typescript": "^6.0.2"
  }
}
