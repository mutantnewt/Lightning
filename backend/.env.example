# Backend runtime configuration
# Use `lightning-<resource>-<env>` for human-named AWS resources.
# Example table names:
# BOOKS_TABLE_NAME=lightning-books-local
# USER_STATE_TABLE_NAME=lightning-user-state-local
# BOOK_SUGGESTIONS_TABLE_NAME=lightning-book-suggestions-local
# Cognito user-pool IDs are AWS-generated, but the underlying pool name should
# still follow the `lightning-` naming convention, for example `lightning-users-local`.

APP_ENV=local
AWS_REGION=eu-west-2
USER_STATE_STORAGE_MODE=
LOCAL_STATE_FILE=
BOOKS_TABLE_NAME=
LOCAL_CATALOG_FILE=
USER_STATE_TABLE_NAME=
BOOK_SUGGESTIONS_TABLE_NAME=
LOCAL_BOOK_SUGGESTIONS_FILE=
COGNITO_USER_POOL_ID=
# AWS-generated app-client ID used for backend JWT client validation.
COGNITO_APP_CLIENT_ID=
CATALOG_MODERATOR_GROUP_NAME=lightning-catalog-moderators-local
CORS_ALLOW_ORIGIN=http://127.0.0.1:5175
# Local Node dev server only. Do not enable this in deployed Lambda environments.
ALLOW_LOCAL_AUTH_HEADERS=
# Optional: used by the privileged Add Book enrichment flow when enabled.
OPENAI_API_KEY=
SES_FROM_EMAIL=
LOG_LEVEL=info

# Local backend entrypoints now auto-load `backend/.env` and then
# `backend/.env.local`. Shell-defined environment variables still win.
