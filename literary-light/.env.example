# Frontend runtime configuration
# Only browser-safe values belong in this file.

VITE_APP_ENV=local
VITE_AWS_REGION=eu-west-2
# AWS generates the user-pool and app-client IDs stored below.
# The underlying Cognito resource names should still use `lightning-<resource>-<env>`.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=
VITE_COGNITO_IDENTITY_POOL_ID=
VITE_CATALOG_MODERATOR_GROUP_NAME=lightning-catalog-moderators-local
# Local full-stack example:
# VITE_API_PUBLIC_BASE_URL=http://127.0.0.1:8787
# VITE_API_AUTH_BASE_URL=http://127.0.0.1:8787
# VITE_API_PRIVILEGED_BASE_URL=http://127.0.0.1:8787
VITE_API_PUBLIC_BASE_URL=http://127.0.0.1:8787
VITE_API_AUTH_BASE_URL=http://127.0.0.1:8787
VITE_API_PRIVILEGED_BASE_URL=http://127.0.0.1:8787
VITE_SITE_URL=http://127.0.0.1:5175

# Do not add `VITE_OPENAI_API_KEY` to new environments.
# Add Book enrichment now runs behind backend authority when used.
